# ====================================================
# .dockerignore - Docker 构建排除文件
# ====================================================

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# 虚拟环境
.venv/
venv/
env/
ENV/
.env.local

# 运行时数据目录（通过 Volume 挂载）
vector_db/
logs/
uploads/
conversations/
memory/
output/

# 前端构建产物
frontend/node_modules/
frontend/dist/

# 版本控制
.git/
.gitignore

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# 测试文件
tests/
*.test.py

# 文档（可选，减小镜像体积）
# docs/
# README.md

# macOS 文件
.DS_Store
._*

# 日志文件
*.log

# 归档目录
archive_*/
