# 腾讯云生产环境部署配置文件
# 复制此文件为 .env，然后根据实际情况修改

# ============================================================
# 日志和调试
# ============================================================
LOG_LEVEL=info                          # debug, info, warning, error

# ============================================================
# 数据库配置
# ============================================================
# 选项 1: 使用本地 PostgreSQL Docker 容器
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=rag_user
# DB_PASSWORD=change_me_with_strong_password
# DB_NAME=rag_db

# 选项 2: 使用腾讯云 CDB PostgreSQL（推荐生产）
# 1. 在腾讯云控制台创建 CDB PostgreSQL 实例
# 2. 获取内网 IP 地址（速度更快，不产生流量费）
DB_HOST=postgresql-xxxxx.postgres.tencentcdb.com   # 替换为你的 CDB 内网地址
DB_PORT=5432
DB_USER=postgres                        # 根据 CDB 设置修改
DB_PASSWORD=your_strong_password_here   # 强密码，16+ 字符
DB_NAME=rag_db

# ============================================================
# Redis 缓存配置
# ============================================================
# 选项 1: 使用本地 Redis Docker 容器
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=change_me
# REDIS_DB=0

# 选项 2: 使用腾讯云 Redis（推荐生产）
# 1. 在腾讯云控制台创建 Redis 实例
# 2. 复制内网地址
REDIS_HOST=redis-xxxxx.redis.tencentcdb.com        # 替换为你的 Redis 内网地址
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password                 # 强密码
REDIS_DB=0

# ============================================================
# API 配置
# ============================================================
API_WORKERS=4                           # Worker 进程数（CPUs × 2）
API_TIMEOUT=30                          # 请求超时秒数

# ============================================================
# 模型配置
# ============================================================
DEFAULT_LLM_PROVIDER=ollama             # ollama, openai, deepseek
DEFAULT_EMBEDDING_MODEL=nomic-embed-text

# Ollama 配置（本地推理）
# OLLAMA_NUM_GPU=0                      # 0=CPU, 1=使用GPU

# ============================================================
# SearXNG 搜索引擎（可选）
# ============================================================
SEARXNG_SECRET=your_random_secret_key_here_min_24_chars

# ============================================================
# 腾讯云对象存储（COS）配置（可选）
# ============================================================
# 用于存储用户上传的文档，而不是本地磁盘
# TENCENT_COS_BUCKET=rag-docs-bucket    # 桶名
# TENCENT_COS_REGION=ap-shanghai        # 地域代码
# TENCENT_SECRET_ID=your_secret_id      # 在腾讯云控制台生成
# TENCENT_SECRET_KEY=your_secret_key    # 在腾讯云控制台生成

# ============================================================
# 其他配置
# ============================================================
VECTOR_STORE_PATH=/app/vector_db        # 向量库本地路径
DOCUMENT_PATH=/app/documents            # 文档本地路径

# 容器资源监控（可选）
CONTAINER_NAME_PREFIX=rag_               # 容器名前缀
