# ============================================================
# 本地开发：OLLAMA_API_URL=http://localhost:11434
# Docker 部署：OLLAMA_API_URL=http://ollama:11434
# ============================================================

# -------- 运行环境 --------
ENV=production
DEBUG=false
LOG_LEVEL=INFO

# -------- 模型提供者（三选一：openai | deepseek | gemini | ollama）--------
MODEL_PROVIDER=deepseek

# OpenAI API 配置
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com

# Gemini API 配置
GEMINI_API_KEY=

# Ollama 本地模型配置（Docker 部署时 URL 改为 http://ollama:11434）
OLLAMA_MODEL=gemma3:4b
OLLAMA_API_URL=http://localhost:11434

# -------- 模型配置 --------
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=deepseek-chat

# -------- 向量数据库配置 --------
# Docker 部署时使用 /app/vector_db，本地开发用 ./vector_db
VECTOR_DB_PATH=./vector_db
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# -------- 检索配置 --------
TOP_K=2
TEMPERATURE=0.7
MAX_TOKENS=800
# MAX_DISTANCE=1.0

# -------- API 服务配置 --------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# -------- Agent 搜索工具（可选）--------
TAVILY_API_KEY=
